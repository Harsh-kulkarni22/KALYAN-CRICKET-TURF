# Kalyan Cricket Turf - Backend Environment Variables Example
# Duplicate this file to .env for local development or configure these on Render / hosting provider.

# Port for the Express server to listen on (e.g. 5000)
PORT=5000

# MongoDB Connection String (Atlas URI)
MONGO_URI=

# JWT secret key for signing user authentication tokens
JWT_SECRET=

# Google API Credentials (For verifying Google SSO Tokens on the backend)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Nodemailer SMTP Configuration (For OTP/reminders, e.g., Gmail)
EMAIL_USER=
EMAIL_PASS=

# Admin User Identification Contact (Admin email/phone)
ADMIN_CONTACT=

# Razorpay payment keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
